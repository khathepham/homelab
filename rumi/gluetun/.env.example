TZ=America/New_York
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
VPN_PORT_FORWARDING=on
VPN_PORT_FORWARDING_PROVIDER=protonvpn
VPN_PORT_FORWARDING_STATUS_FILE=/gluetun/forwarded_port
UPDATER_PERIOD=24h
FIREWALL_OUTBOUND_SUBNETS=192.168.1.0/24,10.0.0.0/16,172.21.0.0/16,172.20.0.0/16
DOT_PROVIDERS=cloudflare,google
PUBLICIP_API=ip2location
LOG_LEVEL=debug
WIREGUARD_PUBLIC_KEY=your_wireguard_public_key
WIREGUARD_PRIVATE_KEY=your_wireguard_private_key
WIREGUARD_ENDPOINT_IP=your_endpoint_ip
WIREGUARD_ADDRESSES=10.2.0.2/32
DNS_ADDRESS=10.2.0.1
PUID=1000
PGID=1000
WEBUI_PORT=8080
QBITTORRENT_SERVER=localhost
QBITTORRENT_PORT=8080
QBITTORRENT_USER=admin
QBITTORRENT_PASS=your_qbittorrent_password
PORT_FORWARDED=/tmp/gluetun/forwarded_port
HTTP_S=http
