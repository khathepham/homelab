# --- Application Settings ---
NODE_ENV=production
PORT_BACKEND=4000
PORT_FRONTEND=3000
SYNC_FREQUENCY='* * * * *'

# --- Docker Compose Service Configuration ---
# PostgreSQL
POSTGRES_DB=open_archive
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_postgres_password
DATABASE_URL=postgresql://admin:your_postgres_password@postgres:5432/open_archive

# Meilisearch
MEILI_MASTER_KEY=your_meilisearch_master_key
MEILI_HOST=http://meilisearch:7700

# Redis / Valkey
REDIS_HOST=valkey
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_TLS_ENABLED=false

# --- Storage Settings ---
STORAGE_TYPE=local
BODY_SIZE_LIMIT=50M
STORAGE_LOCAL_ROOT_PATH=/var/data/open-archiver

# --- S3-Compatible Storage Settings (only if STORAGE_TYPE=s3) ---
STORAGE_S3_ENDPOINT=
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_REGION=
STORAGE_S3_FORCE_PATH_STYLE=false

# --- Security & Authentication ---
JWT_SECRET=a-long-random-secret-string
JWT_EXPIRES_IN=7d
SUPER_API_KEY=your_super_api_key
ENCRYPTION_KEY=your_32_byte_hex_key_run_openssl_rand_-hex_32
ADMIN_EMAIL=admin@your.domain.com
ADMIN_PASSWORD=your_admin_password

# --- Bind Mount Paths ---
OMV_DIR=/omv/docker-volumes
DATA_DIR=/home/USERNAME/data
